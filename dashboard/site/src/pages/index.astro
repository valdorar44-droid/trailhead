---
import Layout from "../layouts/Layout.astro";

const iosUrl = "https://apps.apple.com/au/app/trailhead-camp-route-free/id6763677349";
const androidUrl = "https://play.google.com/store/apps/details?id=com.trailhead.app&gl=us&hl=en_US";
---

<Layout
  title="Trailhead - Camps, trails, routes, and outdoor places"
  description="Trailhead brings camps, trails, route days, map search, and place details into one outdoor travel app."
>
  <main class="trailhead-home">
    <section class="th-hero" id="app" aria-label="Trailhead app">
      <div class="th-hero-inner">
        <div class="th-hero-copy">
          <p class="th-eyebrow">Trailhead</p>
          <h1>Camps, trails, routes, and places in one app.</h1>
          <p class="th-lead">Open the map, compare nearby stops, and build trip days without bouncing between tools.</p>
          <div class="th-actions">
            <a class="th-store-link" href={iosUrl} aria-label="Download Trailhead on the App Store">
              <span>Download on the</span>
              <strong>App Store</strong>
            </a>
            <a class="th-store-link" href={androidUrl} aria-label="Get Trailhead on Google Play">
              <span>Get it on</span>
              <strong>Google Play</strong>
            </a>
            <a class="th-btn th-btn-ghost" href="/app">Open app</a>
          </div>
        </div>

        <div class="th-phone-stack" aria-label="Trailhead app screens">
          <figure class="th-phone-frame th-phone-main">
            <img src="/assets/screenshots/map-main.jpg" alt="Trailhead map screen with nearby camp and water pins" loading="eager" />
          </figure>
          <figure class="th-phone-frame th-phone-side">
            <img src="/assets/screenshots/yosemite-detail.jpg" alt="Trailhead camp detail screen with nearby camp options" loading="eager" />
          </figure>
        </div>
      </div>
    </section>

    <section class="th-section" id="explore">
      <div class="th-shot th-shot-detail">
        <img src="/assets/screenshots/yosemite-detail.jpg" alt="Trailhead Yosemite camp detail screen" loading="lazy" />
      </div>
      <div>
        <p class="th-eyebrow">Explore</p>
        <h2>Every place opens into useful next steps.</h2>
        <p>Browse nearby camps, trails, stays, photos, and route options from the same page.</p>
      </div>
    </section>

    <section class="th-section th-section-map">
      <div>
        <p class="th-eyebrow">Map</p>
        <h2>Find stops around your route.</h2>
        <p>Search camps, water, trailheads, fuel, and places from the same screen.</p>
        <div class="th-actions th-actions-tight">
          <a class="th-btn th-btn-primary" href="/app">Open app</a>
        </div>
      </div>
      <div class="th-shot th-shot-map">
        <img src="/assets/screenshots/map-main.jpg" alt="Trailhead map with camp, water, and route pins" loading="lazy" />
      </div>
    </section>

    <section class="th-closing" id="routes">
      <div>
        <p class="th-eyebrow">Routes</p>
        <h2>Turn stops into a route you can actually use.</h2>
        <p>Build days, inspect stops, and keep the route connected to the places you care about.</p>
      </div>
      <div class="th-actions" id="download">
        <a class="th-btn th-btn-primary" href={iosUrl}>Download iOS</a>
        <a class="th-btn th-btn-primary th-btn-android" href={androidUrl}>Download Android</a>
        <a class="th-btn th-btn-ghost" href="/app">Open app</a>
      </div>
    </section>
  </main>
</Layout>
