---
import BaseHead from "../components/BaseHead.astro";
import Nav from "../components/Nav.jsx";
import Footer from "../components/Footer.jsx";
import { ClientRouter } from "astro:transitions";
import site from "../data/site.json";
const { title, description, image, transparentNav = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} />
    <ClientRouter />
  </head>
  <body>
    {transparentNav ? (
      <div class="absolute inset-x-0 top-0 z-30">
        <Nav
          brand={site.brand}
          links={site.nav}
          active="/"
          transparent={true}
          client:load
        />
      </div>
    ) : (
      <Nav
        brand={site.brand}
        links={site.nav}
        active="/"
        transparent={false}
        client:load
      />
    )}
    <slot />
    <Footer data={site.footer} client:load />
  </body>
</html>
