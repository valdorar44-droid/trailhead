{
  "cli": { "version": ">= 12.0.0" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": { "simulator": false },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://trailhead-production-2049.up.railway.app"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "ios": { "image": "latest" },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://trailhead-production-2049.up.railway.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
