# Trailhead — Environment Variables
# Copy to .env and fill in values

# Required
ANTHROPIC_API_KEY=your_key_here
MAPBOX_TOKEN=pk.eyJ1...
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
AUDIO_CACHE_DIR=./audio_cache
AUDIO_CACHE_R2_PREFIX=audio-cache

# Free API keys (sign up at the URLs below)
NREL_API_KEY=DEMO_KEY          # developer.nrel.gov — use DEMO_KEY for dev
RIDB_API_KEY=your_key_here     # ridb.recreation.gov — free registration
NPS_API_KEY=your_key_here      # nps.gov/subjects/developer — free registration for official park data
ACTIVE_CAMPGROUND_API_KEY=your_key_here       # developer.active.com Campground Search API
ACTIVE_ACTIVITY_SEARCH_API_KEY=your_key_here  # developer.active.com Activity Search API v2
ACTIVE_NET_US_API_KEY=disabled_until_terms_confirmed
ACTIVE_NET_CA_API_KEY=disabled_until_terms_confirmed
ACTIVE_TRAINER_API_KEY=disabled_until_terms_confirmed
ACTIVE_NET_ENABLED=false
FCC_VIZMO_ENABLED=true
FCC_BDC_MOBILE_DATA_DATE=       # e.g. Jun 30 2025, if pinned by deployment
FCC_BDC_MOBILE_SOURCE_URL=https://broadbandmap.fcc.gov/data-download/nationwide-data

# Outdoorsy / TUNE affiliate access. Backend only. Do not expose through Expo.
OUTDOORSY_TUNE_NETWORK_ID=
OUTDOORSY_TUNE_API_KEY=
OUTDOORSY_TUNE_API_BASE_URL=
OUTDOORSY_ENABLE_LIVE=false
OUTDOORSY_PROVIDER_STATE=disabled
OUTDOORSY_REQUEST_TIMEOUT_SECONDS=12
OUTDOORSY_CACHE_TTL_SECONDS=900

# Optional
PORT=8000
TRAILHEAD_DB_PATH=./trailhead.db   # defaults to /data/trailhead.db in prod
VALHALLA_URL=https://your-valhalla-service.example.com

# App Store Server API. Required for trusted production subscription validation.
# Create an In-App Purchase key in App Store Connect, then paste the .p8 key
# with literal \n line breaks or mount it and set APPLE_PRIVATE_KEY_PATH.
APPLE_BUNDLE_ID=com.trailhead.app
APPLE_ISSUER_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_PRIVATE_KEY_PATH=

# Google Play Billing server verification. Optional until Android billing is live,
# but recommended before public Android release.
GOOGLE_PLAY_PACKAGE_NAME=com.trailhead.app
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_SERVICE_ACCOUNT_PATH=
