---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Privacy - Trailhead"
  description="Trailhead privacy notes for accounts, maps, reports, and trip features."
>
  <main class="site-legal">
    <p class="site-kicker">Privacy</p>
    <h1>Privacy</h1>
    <p>Trailhead uses account, map, trip, and report information to run the app and keep saved work connected to your account.</p>
    <p>Payment and store subscriptions are handled by Apple, Google, or the checkout provider shown in the app. Do not share sensitive personal information in public reports.</p>
    <p>Questions can be sent through the app store contact for Trailhead.</p>
    <a class="site-text-link" href="/">Back to Trailhead</a>
  </main>
</Layout>
